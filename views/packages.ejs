<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', { title: 'Treks & Packages' }) %>
</head>
<body>
<%- include('partials/nav') %>

<section class="hero-wrap hero-wrap-2 js-fullheight" style="background-image: url('<%= settings.heroImages[0] %>');">
  <div class="overlay"></div>
  <div class="container">
    <div class="row no-gutters slider-text js-fullheight align-items-end justify-content-center">
      <div class="col-md-9 ftco-animate pb-5 text-center">
        <p class="breadcrumbs"><span class="mr-2"><a href="/">Home <i class="fa fa-chevron-right"></i></a></span> <span>Treks &amp; Packages <i class="fa fa-chevron-right"></i></span></p>
        <h1 class="mb-0 bread">Treks &amp; Packages</h1>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-9 heading-section text-center ftco-animate">
        <span class="subheading">Fixed Departures</span>
        <h2 class="mb-3">Find Your Next Himalayan Adventure</h2>
        <p class="section-intro-text">Every trek below is a fixed-departure journey with transparent pricing, certified local guides, and a support team that follows you from first inquiry to safe return. Filter by region, difficulty, or price to find the route that fits you — whether it's your very first summit or your tenth high pass.</p>
      </div>
    </div>
    <div class="filter-bar">
      <form method="GET" action="/packages" class="row align-items-end">
        <div class="col-md-3">
          <label>Region</label>
          <select name="region" class="form-control">
            <option value="">All regions</option>
            <% regions.forEach(function(r){ %>
              <option value="<%= r %>" <%= query.region === r ? 'selected' : '' %>><%= r %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label>Difficulty</label>
          <select name="difficulty" class="form-control">
            <option value="">Any difficulty</option>
            <% difficulties.forEach(function(d){ %>
              <option value="<%= d %>" <%= query.difficulty === d ? 'selected' : '' %>><%= d %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label>Sort</label>
          <select name="sort" class="form-control">
            <option value="">Featured</option>
            <option value="price_asc" <%= query.sort==='price_asc'?'selected':'' %>>Price low to high</option>
            <option value="price_desc" <%= query.sort==='price_desc'?'selected':'' %>>Price high to low</option>
            <option value="rating" <%= query.sort==='rating'?'selected':'' %>>Highest rated</option>
          </select>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-primary btn-block">Filter</button>
        </div>
      </form>
    </div>

    <div class="row">
      <% if (!packages.length) { %>
        <div class="col-12 text-center py-5">
          <p class="text-muted">No treks match those filters yet. Try a different combination.</p>
        </div>
      <% } %>
      <% packages.forEach(function(pkg) { %>
        <div class="col-md-4 ftco-animate mb-4">
          <div class="project-wrap">
            <a href="/packages/<%= pkg.id %>" class="img" style="background-image: url(<%= pkg.image %>);">
              <span class="price">₹<%= pkg.price.toLocaleString('en-IN') %>/person</span>
            </a>
            <div class="text p-4">
              <span class="days"><%= pkg.duration %> · <span class="badge-difficulty"><%= pkg.difficulty %></span></span>
              <h3><a href="/packages/<%= pkg.id %>"><%= pkg.title %></a></h3>
              <p class="location"><span class="fa fa-map-marker"></span> <%= pkg.location %></p>
              <p class="rating"><span class="fa fa-star" style="color:#F96D00;"></span> <%= pkg.rating %> rating</p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ===== WHY BOOK WITH US ===== -->
<section class="ftco-section bg-light-soft">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">Book With Confidence</span>
        <h2 class="mb-3">Every Trek, Fully Supported</h2>
      </div>
    </div>
    <div class="row">
      <div class="col-md-6 col-lg-3 mb-4 ftco-animate"><div class="value-card text-center"><div class="vc-icon">🧭</div><h3>Certified Guides</h3><p>Local experts trained in high-altitude safety and first aid lead every single departure.</p></div></div>
      <div class="col-md-6 col-lg-3 mb-4 ftco-animate"><div class="value-card text-center"><div class="vc-icon">💰</div><h3>Transparent Pricing</h3><p>What you see is what you pay. Clear inclusions and no hidden charges on any package.</p></div></div>
      <div class="col-md-6 col-lg-3 mb-4 ftco-animate"><div class="value-card text-center"><div class="vc-icon">🗓️</div><h3>Fixed Departures</h3><p>Confirmed dates you can plan around, with small groups for a safer, friendlier trail.</p></div></div>
      <div class="col-md-6 col-lg-3 mb-4 ftco-animate"><div class="value-card text-center"><div class="vc-icon">📞</div><h3>Real Support</h3><p>A dedicated team answers your questions before, during, and after your journey.</p></div></div>
    </div>
  </div>
</section>

<!-- ===== FAQ ===== -->
<section class="ftco-section">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">Good to Know</span>
        <h2 class="mb-3">Booking &amp; Trek FAQs</h2>
      </div>
    </div>
    <div class="row justify-content-center">
      <div class="col-lg-9 ftco-animate">
        <details class="faq-item"><summary>How do I reserve a spot on a trek?</summary><div class="faq-body">Open any trek and send an inquiry with your preferred dates. Our team confirms availability and walks you through a simple booking. Seats are limited to keep groups small.</div></details>
        <details class="faq-item"><summary>What should I pack?</summary><div class="faq-body">Once you book, we share a detailed kit list tailored to the route and season — covering layers, footwear, and essentials. You won't have to guess a thing.</div></details>
        <details class="faq-item"><summary>Can beginners join these treks?</summary><div class="faq-body">Absolutely. Look for treks marked Easy or Moderate, and we'll happily recommend a good first route. Basic fitness and enthusiasm are all you need to start.</div></details>
        <details class="faq-item"><summary>What happens if the weather turns bad?</summary><div class="faq-body">Your safety comes first. Our guides monitor conditions closely and adjust the itinerary when needed. We'd rather change a plan than take an unnecessary risk.</div></details>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
