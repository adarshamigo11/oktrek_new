          <h2 class="ftco-heading-2">Explore</h2>
          <ul class="list-unstyled">
            <li><a href="/packages" class="py-2 d-block">All Treks &amp; Packages</a></li>
            <li><a href="/about" class="py-2 d-block">About Us</a></li>
            <li><a href="/contact" class="py-2 d-block">Contact Us</a></li>
            <li><a href="/contact#inquiry" class="py-2 d-block">Send an Enquiry</a></li>
