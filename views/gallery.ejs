<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', { title: 'Gallery' }) %>
</head>
<body>
<%- include('partials/nav') %>

<section class="hero-wrap hero-wrap-2 js-fullheight" style="background-image: url('<%= settings.heroImages[0] %>');">
  <div class="overlay"></div>
  <div class="container">
    <div class="row no-gutters slider-text js-fullheight align-items-end justify-content-center">
      <div class="col-md-9 ftco-animate pb-5 text-center">
        <p class="breadcrumbs"><span class="mr-2"><a href="/">Home <i class="fa fa-chevron-right"></i></a></span> <span>Gallery <i class="fa fa-chevron-right"></i></span></p>
        <h1 class="mb-0 bread">Photo Gallery</h1>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">Visual Journal</span>
        <h2 class="mb-4">Moments From The Mountains</h2>
        <p>Captures from our Himalayan treks, yatra journeys, and mountain expeditions.</p>
      </div>
    </div>

    <% if (!images.length) { %>
      <div class="row">
        <div class="col-12 text-center py-5">
          <p class="text-muted">Gallery images coming soon. Check back later!</p>
        </div>
      </div>
    <% } else { %>
      <div class="row">
        <% images.forEach(function(img) { %>
          <div class="col-md-3 col-sm-6 mb-4 ftco-animate">
            <div class="gallery-card">
              <a href="<%= img.imageUrl %>" class="gallery-lightbox">
                <img src="<%= img.imageUrl %>" alt="<%= img.caption %>" loading="lazy">
              </a>
              <% if (img.caption) { %>
                <div class="gallery-caption"><%= img.caption %></div>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<style>
.gallery-card {
  border-radius: 8px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.gallery-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}
.gallery-card img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}
.gallery-card:hover img {
  transform: scale(1.05);
}
.gallery-caption {
  padding: 12px 14px;
  font-size: 0.9rem;
  color: #444;
  border-top: 1px solid #f0f0f0;
}
</style>

<%- include('partials/footer') %>
</body>
</html>
