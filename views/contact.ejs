<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', { title: 'Contact Us' }) %>
</head>
<body>
<%- include('partials/nav') %>

<section class="hero-wrap hero-wrap-2 js-fullheight" style="background-image: url('<%= settings.heroImages[2] || settings.heroImages[0] %>');">
  <div class="overlay"></div>
  <div class="container">
    <div class="row no-gutters slider-text js-fullheight align-items-end justify-content-center">
      <div class="col-md-9 ftco-animate pb-5 text-center">
        <p class="breadcrumbs"><span class="mr-2"><a href="/">Home <i class="fa fa-chevron-right"></i></a></span> <span>Contact us <i class="fa fa-chevron-right"></i></span></p>
        <h1 class="mb-0 bread">Contact us</h1>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section ftco-no-pb contact-section mb-4">
  <div class="container">
    <div class="row d-flex contact-info">
      <div class="col-md-4 d-flex">
        <div class="align-self-stretch box p-4 text-center">
          <div class="icon d-flex align-items-center justify-content-center"><span class="fa fa-map-marker"></span></div>
          <h3 class="mb-2">Address</h3>
          <p><%= settings.contact.address %></p>
        </div>
      </div>
      <div class="col-md-4 d-flex">
        <div class="align-self-stretch box p-4 text-center">
          <div class="icon d-flex align-items-center justify-content-center"><span class="fa fa-phone"></span></div>
          <h3 class="mb-2">Contact Number</h3>
          <p><a href="tel:<%= settings.contact.phone %>"><%= settings.contact.phone %></a></p>
        </div>
      </div>
      <div class="col-md-4 d-flex">
        <div class="align-self-stretch box p-4 text-center">
          <div class="icon d-flex align-items-center justify-content-center"><span class="fa fa-paper-plane"></span></div>
          <h3 class="mb-2">Email Address</h3>
          <p><a href="mailto:<%= settings.contact.email %>"><%= settings.contact.email %></a></p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section contact-section ftco-no-pt" id="inquiry">
  <div class="container">
    <div class="row block-9">
      <div class="col-md-6 order-md-last d-flex">
        <form method="POST" action="/contact" class="bg-light p-5 contact-form w-100">
          <% if (submitted) { %>
            <div class="alert alert-success">Thanks for reaching out! We'll get back to you soon.</div>
          <% } %>
          <div class="form-group">
            <input type="text" name="name" class="form-control" placeholder="Your Name" required>
          </div>
          <div class="form-group">
            <input type="email" name="email" class="form-control" placeholder="Your Email" required>
          </div>
          <div class="form-group">
            <input type="text" name="subject" class="form-control" placeholder="Subject">
          </div>
          <div class="form-group">
            <textarea name="message" cols="30" rows="7" class="form-control" placeholder="Message" required></textarea>
          </div>
          <div class="form-group">
            <input type="submit" value="Send Message" class="btn btn-primary py-3 px-5">
          </div>
        </form>
      </div>

      <div class="col-md-6 d-flex">
        <% if (settings.contact.mapEmbed) { %>
          <div class="w-100" style="min-height:400px;"><%- settings.contact.mapEmbed %></div>
        <% } else { %>
          <div id="map" class="bg-white w-100" style="min-height:400px; background:#eee; display:flex; align-items:center; justify-content:center; color:#999;">
            Map — add an embed code from the admin settings page
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
