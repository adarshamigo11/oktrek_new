<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head') %>
</head>
<body>
<%- include('partials/nav') %>

<!-- ===== 3D PARALLAX HERO ===== -->
<div class="hero-parallax">
  <% settings.heroImages.forEach(function(img, i) { %>
    <div class="p3d-layer" data-depth="<%= 12 + i * 4 %>" style="background-image:url('<%= img %>');"></div>
  <% }) %>
  <div class="p3d-overlay"></div>
  <div class="container p3d-content">
    <div class="row no-gutters align-items-center">
      <div class="col-md-8 ftco-animate text-white">
        <span class="subheading" style="color:#F96D00; letter-spacing:2px; text-transform:uppercase; font-weight:600;">Adventure Awaits</span>
        <h1 class="mb-3 mt-2" style="font-size:52px; font-weight:700; color:#fff;">Conquer The Heights</h1>
        <p class="mb-4" style="font-size:19px; opacity:.9;">Where Every Step Tells a Story — guided Himalayan treks and yatra journeys with fixed departures and transparent pricing.</p>
        <p>
          <a href="/packages" class="btn btn-primary py-3 px-4 mr-2">Explore Treks</a>
          <a href="/contact#inquiry" class="btn btn-outline-light py-3 px-4">Send Inquiry</a>
        </p>
      </div>
    </div>
  </div>
</div>
<!-- ===== END HERO ===== -->

<section class="ftco-section">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">Featured Expeditions</span>
        <h2 class="mb-4">Choose Your Adventure</h2>
        <p>Handpicked Himalayan treks and yatra escapes guided by experts who live and breathe the mountains.</p>
      </div>
    </div>
    <div class="row">
      <% packages.forEach(function(pkg) { %>
        <div class="col-md-4 ftco-animate">
          <div class="project-wrap">
            <a href="/packages/<%= pkg.id %>" class="img" style="background-image: url(<%= pkg.image %>);">
              <span class="price">₹<%= pkg.price.toLocaleString('en-IN') %>/person</span>
            </a>
            <div class="text p-4">
              <span class="days"><%= pkg.duration %> · <span class="badge-difficulty"><%= pkg.difficulty %></span></span>
              <h3><a href="/packages/<%= pkg.id %>"><%= pkg.title %></a></h3>
              <p class="location"><span class="fa fa-map-marker"></span> <%= pkg.location %></p>
              <p class="rating"><span class="fa fa-star" style="color:#F96D00;"></span> <%= pkg.rating %> rating</p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <div class="row justify-content-center mt-3">
      <a href="/packages" class="btn btn-primary py-3 px-5">View All Treks</a>
    </div>
  </div>
</section>

<!-- ===== POPULAR REGIONS ===== -->
<section class="ftco-section bg-light-soft">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">Where We Roam</span>
        <h2 class="mb-3">Explore by Region</h2>
        <p class="section-intro-text">From the meadows of Uttarakhand to the cold deserts of Spiti, pick the corner of the Himalaya that's calling you.</p>
      </div>
    </div>
    <div class="row">
      <div class="col-md-6 col-lg-3 mb-4 ftco-animate">
        <a href="/packages?region=Uttarakhand" class="region-card"><div class="bg" style="background-image:url(/images/destination-1.jpg);"></div><div class="region-overlay"></div><div class="region-label"><h3>Uttarakhand</h3><span>Snow trails &amp; sacred peaks</span></div></a>
      </div>
      <div class="col-md-6 col-lg-3 mb-4 ftco-animate">
        <a href="/packages?region=Himachal%20Pradesh" class="region-card"><div class="bg" style="background-image:url(/images/destination-3.jpg);"></div><div class="region-overlay"></div><div class="region-label"><h3>Himachal Pradesh</h3><span>Pine valleys &amp; high passes</span></div></a>
      </div>
      <div class="col-md-6 col-lg-3 mb-4 ftco-animate">
        <a href="/packages" class="region-card"><div class="bg" style="background-image:url(/images/destination-7.jpg);"></div><div class="region-overlay"></div><div class="region-label"><h3>Ladakh &amp; Spiti</h3><span>Cold deserts &amp; ancient monasteries</span></div></a>
      </div>
      <div class="col-md-6 col-lg-3 mb-4 ftco-animate">
        <a href="/packages" class="region-card"><div class="bg" style="background-image:url(/images/destination-4.jpg);"></div><div class="region-overlay"></div><div class="region-label"><h3>Sacred Yatras</h3><span>Guided pilgrimage journeys</span></div></a>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section ftco-about ftco-no-pt img" style="background-image: url(<%= settings.introBg %>);">
  <div class="overlay"></div>
  <div class="container py-md-5">
    <div class="row py-md-5 justify-content-center text-center">
      <div class="col-md-8 text-white">
        <span class="subheading" style="color:#F96D00;">By The Numbers</span>
        <h2 class="mb-4">Our Trekking Legacy</h2>
        <div class="row trekking-legacy">
          <div class="col-6 col-md-3 mb-4">
            <div class="icon-number"><span style="font-size:36px; font-weight:700;"><%= settings.stats.routes %>+</span></div>
            <p>Routes Covered</p>
          </div>
          <div class="col-6 col-md-3 mb-4">
            <div class="icon-number"><span style="font-size:36px; font-weight:700;"><%= settings.stats.travellers %>+</span></div>
            <p>Happy Travellers</p>
          </div>
          <div class="col-6 col-md-3 mb-4">
            <div class="icon-number"><span style="font-size:36px; font-weight:700;"><%= settings.stats.teams %>+</span></div>
            <p>Mountain Teams</p>
          </div>
          <div class="col-6 col-md-3 mb-4">
            <div class="icon-number"><span style="font-size:36px; font-weight:700;"><%= settings.stats.satisfaction %>%</span></div>
            <p>Satisfaction Rate</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">The Oktrek Experience</span>
        <h2 class="mb-4">Why Trek With Us</h2>
      </div>
    </div>
    <div class="row">
      <div class="col-md-3 text-center mb-4">
        <div style="font-size:40px;">🧭</div>
        <h3 class="h5 mt-2">Expert Local Guides</h3>
        <p class="small text-muted">Certified mountain teams with deep local knowledge across routes, weather windows, and safe pacing.</p>
      </div>
      <div class="col-md-3 text-center mb-4">
        <div style="font-size:40px;">🎒</div>
        <h3 class="h5 mt-2">Transparent Planning</h3>
        <p class="small text-muted">Clear departures, pricing, inclusions, and operations follow-up from inquiry to return drop.</p>
      </div>
      <div class="col-md-3 text-center mb-4">
        <div style="font-size:40px;">🌱</div>
        <h3 class="h5 mt-2">Responsible Travel</h3>
        <p class="small text-muted">Trail-first itineraries built around safety, local communities, and low-impact mountain practices.</p>
      </div>
      <div class="col-md-3 text-center mb-4">
        <div style="font-size:40px;">🏥</div>
        <h3 class="h5 mt-2">Safety Support</h3>
        <p class="small text-muted">Operations teams track every trip with practical support for high-altitude and yatra conditions.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== HOW IT WORKS ===== -->
<section class="ftco-section bg-light-soft">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">Simple &amp; Stress-Free</span>
        <h2 class="mb-3">How It Works</h2>
        <p class="section-intro-text">Booking your Himalayan adventure takes just four easy steps — we handle the hard parts so you can focus on the trail.</p>
      </div>
    </div>
    <div class="row">
      <div class="col-md-6 col-lg-3 ftco-animate"><div class="step-card"><div class="step-num">1</div><h3>Pick Your Trek</h3><p>Browse fixed departures and choose the route, region, and difficulty that fits you best.</p></div></div>
      <div class="col-md-6 col-lg-3 ftco-animate"><div class="step-card"><div class="step-num">2</div><h3>Send an Inquiry</h3><p>Drop us your dates and questions. A real person replies with honest advice — no pushy sales.</p></div></div>
      <div class="col-md-6 col-lg-3 ftco-animate"><div class="step-card"><div class="step-num">3</div><h3>Confirm &amp; Prepare</h3><p>Lock your seat with a simple booking. We share a kit list, fitness tips, and a clear itinerary.</p></div></div>
      <div class="col-md-6 col-lg-3 ftco-animate"><div class="step-card"><div class="step-num">4</div><h3>Hit the Trail</h3><p>Meet your guide, join the group, and start walking. We take care of logistics from start to finish.</p></div></div>
    </div>
  </div>
</section>

<section class="ftco-section">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">Visual Journal</span>
        <h2 class="mb-4">Capture the Untamed</h2>
        <p>Moments from Himalayan routes, fixed departures, and guided mountain escapes.</p>
      </div>
    </div>
    <div class="row">
      <% settings.gallery.forEach(function(img) { %>
        <div class="col-md-4 col-6 mb-4">
          <div style="height:220px; background-size:cover; background-position:center; border-radius:6px; background-image:url('<%= img %>');"></div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ===== TESTIMONIALS ===== -->
<section class="ftco-section bg-light-soft">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">Trekker Stories</span>
        <h2 class="mb-3">What Our Travellers Say</h2>
        <p class="section-intro-text">Thousands of walkers have trusted us with their mountain days. Here's a taste of what they took home.</p>
      </div>
    </div>
    <div class="row">
      <div class="col-md-4 mb-4 ftco-animate">
        <div class="testimonial-card"><div class="stars">★★★★★</div><p class="quote">“Best organised trek I've ever done. The guide's calm confidence made a huge difference on summit day.”</p><div class="person"><img src="/images/person_1.jpg" class="avatar" alt="Aditi"><div><strong>Aditi Sharma</strong><span>Kedarkantha Trek</span></div></div></div>
      </div>
      <div class="col-md-4 mb-4 ftco-animate">
        <div class="testimonial-card"><div class="stars">★★★★★</div><p class="quote">“Transparent pricing, punctual pickups, and a team that genuinely cared. I felt looked after the entire journey.”</p><div class="person"><img src="/images/person_2.jpg" class="avatar" alt="Rahul"><div><strong>Rahul Verma</strong><span>Char Dham Yatra</span></div></div></div>
      </div>
      <div class="col-md-4 mb-4 ftco-animate">
        <div class="testimonial-card"><div class="stars">★★★★★</div><p class="quote">“Small group, stunning campsites, and sunrises straight out of a dream. Already planning my next one with them.”</p><div class="person"><img src="/images/person_4.jpg" class="avatar" alt="Karan"><div><strong>Karan Mehta</strong><span>Hampta Pass Trek</span></div></div></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== FAQ ===== -->
<section class="ftco-section">
  <div class="container">
    <div class="row justify-content-center pb-4">
      <div class="col-md-8 heading-section text-center ftco-animate">
        <span class="subheading">Good to Know</span>
        <h2 class="mb-3">Frequently Asked Questions</h2>
        <p class="section-intro-text">Everything first-time trekkers usually ask us before locking in a departure.</p>
      </div>
    </div>
    <div class="row justify-content-center">
      <div class="col-lg-9 ftco-animate">
        <details class="faq-item"><summary>Do I need prior trekking experience?</summary><div class="faq-body">Most of our treks are beginner-friendly. Each listing shows a difficulty rating, and we're happy to suggest a route that matches your fitness. A little cardio prep beforehand goes a long way.</div></details>
        <details class="faq-item"><summary>What's included in the trek price?</summary><div class="faq-body">Typically accommodation on the trail, meals during the trek, permits, a certified guide, and support staff. Each package page lists exact inclusions and exclusions so there are no surprises.</div></details>
        <details class="faq-item"><summary>How large are the groups?</summary><div class="faq-body">We deliberately keep groups small for safety and a better experience. This means more personal attention from your guide and a lighter footprint on the trail.</div></details>
        <details class="faq-item"><summary>Is it safe at high altitude?</summary><div class="faq-body">Safety is our top priority. Itineraries include proper acclimatisation days, our guides are first-aid trained, and we carry the right gear. If conditions aren't safe, we adjust the plan.</div></details>
        <details class="faq-item"><summary>How do I book a departure?</summary><div class="faq-body">Just send an inquiry through any trek page or our contact form. We'll confirm availability, answer your questions, and guide you through a simple booking process.</div></details>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section ftco-intro ftco-no-pt">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-12 text-center">
        <div class="img" style="background-image: url(<%= settings.introBg %>);">
          <div class="overlay"></div>
          <h2>Ready to Write Your Own Mountain Story?</h2>
          <p>Send an inquiry and our team will help match you to the right departure.</p>
          <p class="mb-0"><a href="/contact#inquiry" class="btn btn-primary px-4 py-3">Book Your Trek</a></p>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
